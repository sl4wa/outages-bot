{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(nl -ba *)",
      "Bash(sed -n *)",
      "Bash(go test *)",
      "Bash(make test)",
      "Bash(make build)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./data/users/**)",
      "Read(./var/**)"
    ]
  }
}
